#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

C_CYAN="\033[1;36m"; C_GREEN="\033[1;32m"; C_YELLOW="\033[1;33m"; C_RESET="\033[0m"

banner(){
  echo -e "${C_CYAN}"
  echo "╔══════════════════════════════════════════════╗"
  echo "║        ALCHEMICAL AGENT ECOSYSTEM CLI       ║"
  echo "╚══════════════════════════════════════════════╝"
  echo -e "${C_RESET}"
}

open_url(){
  local url="$1"
  # Prefer Windows opener in WSL for reliability
  if grep -qi microsoft /proc/version 2>/dev/null && command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe /c start "$url" >/dev/null 2>&1 || true
    return
  fi
  if command -v xdg-open >/dev/null 2>&1; then
    xdg-open "$url" >/dev/null 2>&1 || true
  elif command -v powershell.exe >/dev/null 2>&1; then
    powershell.exe /c start "$url" >/dev/null 2>&1 || true
  elif command -v open >/dev/null 2>&1; then
    open "$url" >/dev/null 2>&1 || true
  fi
}

is_http_up(){
  local url="$1"
  curl -fsS --max-time 2 "$url" >/dev/null 2>&1
}

port_pid(){
  local port="$1"
  if command -v lsof >/dev/null 2>&1; then
    lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | head -n1 || true
    return
  fi
  if command -v ss >/dev/null 2>&1; then
    ss -ltnp "( sport = :$port )" 2>/dev/null | sed -n '2p' | sed -n 's/.*pid=\([0-9]\+\).*/\1/p' || true
    return
  fi
  echo ""
}

pid_cmd(){
  local pid="$1"
  ps -p "$pid" -o args= 2>/dev/null || true
}

help(){
  cat <<TXT
Usage: ./scripts/alchemical <command> [options]

Commands:
  wizard                   Wizard premium de instalación (recomendado)
  install [opts]           Instala stack (pasa opciones a infra/scripts/install.sh)
  install-fast [opts]      Instalación rápida (equivale a install --fast)
  up                       Levanta stack completo (16g/32g)
  up-2g                    Levanta perfil 2GB
  up-4g                    Levanta perfil 4GB
  up-8g                    Levanta perfil 8GB
  up-fast                  Arranque rápido sin build (perfil 2g)
  down                     Detiene servicios
  restart                  Reinicia servicios
  status                   Estado de servicios
  logs [service]           Logs en vivo (opcional: servicio)
  dashboard                Arranca dashboard dev fijo en :3000 (o reutiliza si ya está arriba)
  open-dashboard           Abre dashboard runtime en navegador
  open                     Alias de open-dashboard
  update                   Actualiza desde origin/main y recompone stack (y abre dashboard)
  update-fast              Actualiza rápido sin rebuild completo (pull + up -d, y abre dashboard)
  update-safe              Actualización segura con checks + smoke tests + backup
  rollback                 Rollback al último commit bueno desplegado
  doctor                   Chequeo rápido de entorno + secret scan
  scan-secrets             Escaneo manual de secretos en archivos trackeados
  setup-hooks              Activa hook local pre-commit de seguridad

Examples:
  ./scripts/alchemical wizard
  ./scripts/alchemical install --domain localhost --profile 4g --model anthropic/claude-sonnet-4.5
  ./scripts/alchemical install-fast --profile 2g
  ./scripts/alchemical up-2g
  ./scripts/alchemical update
  ./scripts/alchemical update-safe
  ./scripts/alchemical rollback
  ./scripts/alchemical dashboard
TXT
}

doctor(){
  echo -e "${C_CYAN}Preflight${C_RESET}"
  command -v docker >/dev/null && echo -e "${C_GREEN}✓ docker${C_RESET}" || echo "✗ docker missing"
  docker compose version >/dev/null 2>&1 && echo -e "${C_GREEN}✓ docker compose${C_RESET}" || echo "✗ docker compose missing"
  command -v node >/dev/null && echo -e "${C_GREEN}✓ node${C_RESET}" || echo -e "${C_YELLOW}• node missing (solo necesario para dashboard)${C_RESET}"
  echo -e "${C_CYAN}Security${C_RESET}"
  scripts/security/check-secrets.sh
}

setup_hooks(){
  git config core.hooksPath .githooks
  echo -e "${C_GREEN}✓ hooks activados (.githooks/pre-commit)${C_RESET}"
}

wizard(){
  banner
  echo "Iniciando wizard elegante..."
  bash infra/scripts/install.sh --wizard
}

export DOCKER_BUILDKIT="${DOCKER_BUILDKIT:-1}"
export COMPOSE_DOCKER_CLI_BUILD="${COMPOSE_DOCKER_CLI_BUILD:-1}"

case "${1:-help}" in
  wizard) shift; wizard "$@" ;;
  install) shift; bash infra/scripts/install.sh "$@" ;;
  install-fast) shift; bash infra/scripts/install.sh --fast "$@" ;;
  up) docker compose up -d --build ;;
  up-2g) docker compose up -d --build caddy redis chromadb alchemical-gateway velktharion synapsara ;;
  up-4g) docker compose up -d --build caddy redis chromadb alchemical-gateway velktharion synapsara kryonexus ignivox ;;
  up-8g) docker compose up -d --build caddy redis chromadb alchemical-gateway velktharion synapsara kryonexus ignivox auralith resonvyr ;;
  up-fast) docker compose up -d caddy redis chromadb alchemical-gateway velktharion synapsara ;;
  down) docker compose down ;;
  restart) docker compose down && docker compose up -d --build ;;
  status) docker compose ps ;;
  logs) shift; docker compose logs -f ${1:-} ;;
  dashboard)
    if [[ -f .env ]]; then
      export ALCHEMICAL_GATEWAY_TOKEN="$(grep -E '^ALCHEMICAL_GATEWAY_TOKEN=' .env | head -n1 | cut -d'=' -f2-)"
    fi

    if is_http_up "http://localhost:3000"; then
      echo -e "${C_GREEN}✓ dashboard dev ya está activo en http://localhost:3000${C_RESET}"
      open_url "http://localhost:3000"
      exit 0
    fi

    pid="$(port_pid 3000)"
    if [[ -n "$pid" ]]; then
      cmd="$(pid_cmd "$pid")"
      if echo "$cmd" | grep -qiE 'next( |$)'; then
        echo -e "${C_YELLOW}• puerto 3000 ocupado por proceso Next.js (PID $pid). Reiniciando...${C_RESET}"
        kill "$pid" >/dev/null 2>&1 || true
        sleep 1
      else
        echo -e "${C_YELLOW}• puerto 3000 ocupado por: ${cmd}${C_RESET}"
        echo -e "${C_YELLOW}• no se fuerza cierre. Libera :3000 o usa open-dashboard (runtime en :80).${C_RESET}"
        exit 1
      fi
    fi

    cd apps/alchemical-dashboard
    if [[ ! -d node_modules ]]; then npm install; fi
    (
      for _ in $(seq 1 90); do
        if is_http_up "http://localhost:3000"; then
          open_url "http://localhost:3000"
          break
        fi
        sleep 1
      done
    ) >/dev/null 2>&1 &
    npm run dev -- -p 3000
    ;;
  open-dashboard|open)
    if is_http_up "http://localhost:3000"; then
      open_url "http://localhost:3000"
      echo -e "${C_GREEN}✓ abierto dashboard dev: http://localhost:3000${C_RESET}"
    elif is_http_up "http://localhost"; then
      open_url "http://localhost"
      echo -e "${C_GREEN}✓ abierto runtime dashboard: http://localhost${C_RESET}"
    else
      echo -e "${C_YELLOW}• dashboard no está arriba. Usa: ./scripts/alchemical up-fast o ./scripts/alchemical dashboard${C_RESET}"
      exit 1
    fi
    ;;
  update)
    git fetch origin main
    git pull --rebase origin main
    docker compose up -d --build
    open_url "http://localhost"
    echo -e "${C_GREEN}✓ update completo. Dashboard: http://localhost${C_RESET}"
    ;;
  update-fast)
    git fetch origin main
    git pull --rebase origin main
    docker compose up -d
    open_url "http://localhost"
    echo -e "${C_GREEN}✓ update rápido. Dashboard: http://localhost${C_RESET}"
    ;;
  update-safe)
    bash ops/update-safe.sh
    ;;
  rollback)
    bash ops/rollback.sh
    ;;
  doctor) doctor ;;
  scan-secrets) scripts/security/check-secrets.sh ;;
  setup-hooks) setup_hooks ;;
  help|-h|--help) help ;;
  *) echo "Unknown command: $1"; help; exit 1 ;;
esac
