DOMAIN=localhost
EMAIL=admin@localhost
DATA_ROOT=/opt/smouj/persistence
MODEL_ROOT=/opt/smouj/models

# ── KiloCode AI Gateway ──────────────────────────────────────────
# Get your API key at: https://app.kilo.ai (Profile → scroll to bottom)
# Free models available (no key needed for :free suffix models)
KILO_API_KEY=
KILO_DEFAULT_MODEL=anthropic/claude-sonnet-4.5
KILO_BASE_URL=https://api.kilo.ai/api/gateway

# ── OpenClaw Integration ─────────────────────────────────────────
# Configure OpenClaw AI assistant integration
OPENCLAW_API_KEY=
OPENCLAW_BASE_URL=https://api.openclaw.ai/v1

# ── Additional AI Providers (optional) ───────────────────────────
# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic - https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google AI (Gemini) - https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Ollama (local models) - http://localhost:11434
OLLAMA_HOST=http://localhost:11434
